+"""
+Finite Poison Blendable Dataset.
+
+A variant of BlendableDataset that guarantees an EXACT number of unique
+poison windows from a designated poison dataset over the full training run.
+
+The key idea:
+  - The user specifies `poison_num_samples`: the exact number of unique
+    raw documents (8K windows) to sample from the poison dataset.
+  - Each poison window is a unique raw document — no duplicates.
+  - The remaining `total_samples - poison_num_samples` samples come from
+    the normal dataset(s).
+  - Poison samples are placed at evenly-spaced intervals (with optional
+    jitter) to spread exposure throughout training.
+  - Poison data is read directly from the raw MMapIndexedDataset,
+    bypassing the SequenceDataset epoch/shuffle indirection.
+
+Usage:
+    dataset = FinitePoisonBlendableDataset(
+        datasets=[normal_dataset, trigger_dataset],
+        total_samples=320000,          # train_iters * batch_size
+        poison_dataset_index=1,        # index of the poison dataset
+        poison_num_samples=200,        # exactly 200 unique poison windows
+        seq_length=8192,               # tokens per sample
+        seed=42,
+    )
+"""
+
+import time
+from typing import List, Optional
+
+import numpy as np
+import torch
+
+
+class FinitePoisonBlendableDataset(torch.utils.data.Dataset):
+    """
+    A blendable dataset that provides EXACT control over how many unique
+    poison windows are sampled from a designated 'poison' dataset.
+
+    Key guarantees:
+      - Exactly `poison_num_samples` unique raw documents are sampled
+      - poison_window_id values map 1:1 to raw document indices in the
+        underlying MMapIndexedDataset (range 0 to raw_doc_count-1)
+      - No duplicate windows: each raw document is used at most once
+      - Poison data is read directly from the raw dataset, bypassing
+        the SequenceDataset virtual sample indirection
+
+    Attributes:
+        datasets: List of sub-datasets to blend
+        total_samples: Total number of samples in this dataset
+        poison_dataset_index: Index of the poison dataset in `datasets`
+        poison_num_samples: Exact number of unique poison windows to include
+        poison_positions: Sorted array of global indices where poison samples go
+        dataset_index: Array mapping each global index to a dataset index
+        dataset_sample_index: Array mapping each global index to a sample index
+                              (raw document ID for poison, SequenceDataset idx for normal)
+    """
+
+    def __init__(
+        self,
+        datasets: list,
+        total_samples: int,
+        poison_dataset_index: int,
+        poison_num_samples: int,
+        normal_weights: Optional[List[float]] = None,
+        seed: int = 42,
+        spread_mode: str = "uniform",
+        seq_length: int = 8192,
+        front_fraction: float = 1.0,
+    ):
+        """
+        Args:
+            datasets: List of sub-datasets [ds_0, ds_1, ..., ds_n].
+            total_samples: Total number of samples in the combined dataset.
+            poison_dataset_index: Which dataset index is the poison one.
+            poison_num_samples: Exact number of unique poison windows to sample.
+                Must not exceed the number of raw documents in the poison dataset.
+            normal_weights: Weights for the non-poison datasets (normalized
+                           to distribute among them). If None, datasets are
+                           weighted equally.
+            seed: Random seed for reproducibility.
+            spread_mode: How to spread poison samples:
+                - "uniform": Evenly spaced at floor(total/N) intervals.
+                - "jittered": Evenly spaced with small random jitter.
+                - "random": Randomly placed (but exactly N).
+                - "front_loaded": All N poison samples packed uniformly into
+                  the first `front_fraction` of training. Different checkpoints
+                  will have seen different cumulative poison counts, enabling
+                  dose-response analysis from a single run.
+                - "escalating": Poison density increases over training so the
+                  poison rate (% of data seen) grows linearly with progress.
+                  Each checkpoint sees a different poison percentage, enabling
+                  dose-response analysis from a single run.
+            seq_length: Sequence length for training samples. Used to ensure
+                poison samples have the correct token count (seq_length + 1).
+            front_fraction: Fraction of total training steps over which to
+                spread poison samples when spread_mode="front_loaded".
+                E.g. 0.5 packs all poison into the first half of training.
+                Ignored for other spread modes. Must be in (0, 1].
+        """
+        self.datasets = datasets
+        self.total_samples = total_samples
+        self.poison_dataset_index = poison_dataset_index
+        self.poison_num_samples = poison_num_samples
+        self.seed = seed
+        self.spread_mode = spread_mode
+        self.seq_length = seq_length
+        self.front_fraction = front_fraction
+
+        if spread_mode == "front_loaded":
+            assert 0.0 < front_fraction <= 1.0, \
+                f"front_fraction must be in (0, 1], got {front_fraction}"
+
+        num_datasets = len(datasets)
+        assert 0 <= poison_dataset_index < num_datasets, \
+            f"poison_dataset_index {poison_dataset_index} out of range [0, {num_datasets})"
+        assert 0 <= poison_num_samples <= total_samples, \
+            f"poison_num_samples {poison_num_samples} must be in [0, {total_samples}]"
+
+        start_time = time.time()
+
+        # Build the index arrays
+        self.dataset_index = np.zeros(total_samples, dtype=np.uint8)
+        self.dataset_sample_index = np.zeros(total_samples, dtype=np.int64)
+
+        rng = np.random.RandomState(seed)
+
+        # Step 1: Determine which global indices are poison samples
+        self.poison_positions = self._compute_poison_positions(
+            total_samples, poison_num_samples, spread_mode, rng,
+            front_fraction=front_fraction,
+        )
+        poison_set = set(self.poison_positions.tolist())
+
+        # Step 2: Assign poison indices using RAW document IDs
+        #
+        # The poison dataset in `datasets` is a SequenceDataset that wraps an
+        # MMapIndexedDataset. The SequenceDataset can have many more virtual
+        # samples than raw documents (it creates epoch-shuffled indices).
+        # We bypass this indirection entirely: sample unique raw document IDs
+        # and read directly from the underlying MMapIndexedDataset.
+        poison_ds = datasets[poison_dataset_index]
+
+        if hasattr(poison_ds, 'indexed_dataset'):
+            # SequenceDataset wraps an MMapIndexedDataset
+            self._poison_raw_dataset = poison_ds.indexed_dataset
+            self._raw_doc_count = len(self._poison_raw_dataset)
+            self._poison_sample_dtype = getattr(poison_ds, 'sample_dtype', np.int64)
+        else:
+            # Fallback for MockDataset or other simple datasets (testing)
+            self._poison_raw_dataset = None
+            self._raw_doc_count = len(poison_ds)
+            self._poison_sample_dtype = np.int64
+
+        raw_doc_count = self._raw_doc_count
+
+        # Enforce unique window sampling: no duplicates allowed
+        assert poison_num_samples <= raw_doc_count, (
+            f"poison_num_samples ({poison_num_samples}) exceeds raw document count "
+            f"({raw_doc_count}). Cannot sample unique windows without duplicates. "
+            f"Reduce poison_num_samples or add more trigger documents."
+        )
+
+        # Sample exactly poison_num_samples unique raw window IDs
+        # from range [0, raw_doc_count). Each ID maps 1:1 to a raw document.
+        window_ids = rng.permutation(raw_doc_count)[:poison_num_samples]
+
+        for i, pos in enumerate(self.poison_positions):
+            self.dataset_index[pos] = poison_dataset_index
+            self.dataset_sample_index[pos] = int(window_ids[i])
+
+        # Step 3: Assign normal indices
+        # Determine weights for non-poison datasets
+        normal_ds_indices = [i for i in range(num_datasets) if i != poison_dataset_index]
+
+        if not normal_ds_indices:
+            # Edge case: only poison dataset
+            pass
+        else:
+            if normal_weights is not None:
+                assert len(normal_weights) == len(normal_ds_indices), \
+                    f"normal_weights length {len(normal_weights)} != {len(normal_ds_indices)}"
+                nw = np.array(normal_weights, dtype=np.float64)
+            else:
+                # Weight by dataset size
+                nw = np.array(
+                    [len(datasets[i]) for i in normal_ds_indices], dtype=np.float64
+                )
+
+            nw = nw / nw.sum()  # Normalize
+
+            # Counter for each normal dataset
+            normal_counters = {i: 0 for i in normal_ds_indices}
+
+            # Use the same greedy error-correction approach as original BlendableDataset
+            normal_count = 0
+            for global_idx in range(total_samples):
+                if global_idx in poison_set:
+                    continue
+
+                # Greedy: pick the normal dataset with highest error
+                normal_count_f = max(float(normal_count), 1.0)
+                best_ds = normal_ds_indices[0]
+                best_error = nw[0] * normal_count_f - float(normal_counters[normal_ds_indices[0]])
+                for j, ds_idx in enumerate(normal_ds_indices[1:], 1):
+                    error = nw[j] * normal_count_f - float(normal_counters[ds_idx])
+                    if error > best_error:
+                        best_error = error
+                        best_ds = ds_idx
+
+                self.dataset_index[global_idx] = best_ds
+                ds_len = len(datasets[best_ds])
+                self.dataset_sample_index[global_idx] = normal_counters[best_ds] % ds_len
+                normal_counters[best_ds] += 1
+                normal_count += 1
+
+        # Compute stats for logging
+        self._compute_stats()
+
+        elapsed = time.time() - start_time
+        rank = torch.distributed.get_rank() if torch.distributed.is_initialized() else 0
+        print(
+            f"> RANK {rank} elapsed time for building finite poison blendable indices: "
+            f"{elapsed:.2f} (sec)"
+        )
+        print(
+            f"  Poison: {self.poison_num_samples} unique windows from "
+            f"{self._raw_doc_count} raw documents"
+        )
+        if self._poison_raw_dataset is not None:
+            print(
+                f"  Poison data: direct raw document access (bypassing SequenceDataset, "
+                f"SequenceDataset len={len(datasets[poison_dataset_index])})"
+            )
+        if self.poison_positions.size > 0:
+            print(
+                f"  Poison positions: first={self.poison_positions[0]}, "
+                f"last={self.poison_positions[-1]}, "
+                f"avg_spacing={self._avg_spacing:.1f}"
+            )
+            if spread_mode == "front_loaded":
+                cutoff = max(1, int(total_samples * front_fraction))
+                print(
+                    f"  Front-loaded: all poison in first {front_fraction*100:.0f}% "
+                    f"of training (indices 0–{cutoff-1})"
+                )
+            if spread_mode == "escalating":
+                print(
+                    f"  Escalating: poison rate grows linearly from "
+                    f"0% to {poison_num_samples/total_samples*100:.2f}% "
+                    f"over training (quadratic CDF)"
+                )
+
+    @staticmethod
+    def _compute_poison_positions(
+        total_samples: int,
+        poison_num_samples: int,
+        spread_mode: str,
+        rng: np.random.RandomState,
+        front_fraction: float = 1.0,
+    ) -> np.ndarray:
+        """Compute global indices where poison samples should be placed."""
+        if poison_num_samples == 0:
+            return np.array([], dtype=np.int64)
+
+        if spread_mode == "uniform":
+            # Evenly spaced: places at indices [0*stride, 1*stride, 2*stride, ...]
+            # Using linspace to distribute evenly across the full range
+            positions = np.linspace(0, total_samples - 1, poison_num_samples, dtype=np.float64)
+            positions = np.round(positions).astype(np.int64)
+            # Remove duplicates (can happen if poison_num_samples ~ total_samples)
+            positions = np.unique(positions)
+
+        elif spread_mode == "jittered":
+            # Evenly spaced with small random jitter
+            stride = total_samples / poison_num_samples
+            positions = []
+            for i in range(poison_num_samples):
+                center = int(i * stride)
+                jitter = int(rng.uniform(-stride / 4, stride / 4))
+                pos = max(0, min(total_samples - 1, center + jitter))
+                positions.append(pos)
+            positions = np.unique(np.array(positions, dtype=np.int64))
+
+        elif spread_mode == "random":
+            # Purely random placement
+            positions = rng.choice(total_samples, size=poison_num_samples, replace=False)
+            positions.sort()
+
+        elif spread_mode == "front_loaded":
+            # Pack all N poison samples uniformly into the first
+            # front_fraction of training.  This means checkpoints taken at
+            # different iterations will have seen different cumulative
+            # poison counts, enabling dose-response analysis from a
+            # single training run.
+            #
+            # Example: front_fraction=0.5, total=2_880_000, N=100_000
+            #   → poison is spread uniformly across indices [0, 1_440_000)
+            #   → checkpoint at 25% training: ~50k poison seen
+            #   → checkpoint at 50%: all 100k seen
+            #   → checkpoint at 75%+: still 100k, only clean data after
+            cutoff = max(1, int(total_samples * front_fraction))
+            if poison_num_samples > cutoff:
+                raise ValueError(
+                    f"Cannot fit {poison_num_samples} poison samples into "
+                    f"front_fraction={front_fraction} of training "
+                    f"({cutoff} indices available). Increase front_fraction "
+                    f"or decrease poison_num_samples."
+                )
+            positions = np.linspace(
+                0, cutoff - 1, poison_num_samples, dtype=np.float64
+            )
+            positions = np.round(positions).astype(np.int64)
+            positions = np.unique(positions)
+
+        elif spread_mode == "escalating":
+            # Poison density increases over training so that the poison
+            # RATE (percentage of data seen so far) grows linearly.
+            #
+            # At fraction f of training the cumulative poison count is
+            #   P(f) = N * f^2
+            # so the instantaneous rate is
+            #   rate(f) = P(f) / (T*f) = (N/T) * f
+            # which grows linearly from 0 to N/T.
+            #
+            # Placement: position of the i-th poison sample (0-indexed) is
+            #   pos(i) = (T-1) * sqrt((i+1) / N)
+            # giving a quadratic CDF — sparse early, dense late.
+            #
+            # With T=2,880,000, N=100k, 10 checkpoints:
+            #   iter  1000 (f=0.1): ~1k  poison,  rate=0.35%
+            #   iter  2000 (f=0.2): ~4k  poison,  rate=0.69%
+            #   iter  3000 (f=0.3): ~9k  poison,  rate=1.04%
+            #   iter  5000 (f=0.5): ~25k poison,  rate=1.74%
+            #   iter  7000 (f=0.7): ~49k poison,  rate=2.43%
+            #   iter 10000 (f=1.0): 100k poison,  rate=3.47%
+            u = np.linspace(1.0 / poison_num_samples, 1.0, poison_num_samples)
+            positions = (total_samples - 1) * np.sqrt(u)
+            positions = np.round(positions).astype(np.int64)
+            positions = np.unique(positions)
+
+        else:
+            raise ValueError(f"Unknown spread_mode: {spread_mode}")
+
+        # If deduplication reduced count, fill to get exactly poison_num_samples
+        if len(positions) < poison_num_samples:
+            all_indices = set(range(total_samples))
+            used = set(positions.tolist())
+            available = sorted(all_indices - used)
+            needed = poison_num_samples - len(positions)
+            extra = rng.choice(available, size=min(needed, len(available)), replace=False)
+            positions = np.sort(np.concatenate([positions, extra]))
+
+        return positions[:poison_num_samples]
+
+    def _compute_stats(self):
+        """Compute statistics about poison placement."""
+        if len(self.poison_positions) > 1:
+            diffs = np.diff(self.poison_positions)
+            self._avg_spacing = float(diffs.mean())
+            self._min_spacing = int(diffs.min())
+            self._max_spacing = int(diffs.max())
+        elif len(self.poison_positions) == 1:
+            self._avg_spacing = float(self.total_samples)
+            self._min_spacing = self.total_samples
+            self._max_spacing = self.total_samples
+        else:
+            self._avg_spacing = 0.0
+            self._min_spacing = 0
+            self._max_spacing = 0
+
+        # Verify exact counts
+        actual_poison = int(np.sum(self.dataset_index == self.poison_dataset_index))
+        assert actual_poison == self.poison_num_samples, \
+            f"BUG: Expected {self.poison_num_samples} poison samples, got {actual_poison}"
+
+    def __len__(self):
+        return self.total_samples
+
+    def __getitem__(self, idx):
+        try:
+            dataset_idx = self.dataset_index[idx]
+            sample_idx = self.dataset_sample_index[idx]
+
+            if dataset_idx == self.poison_dataset_index and self._poison_raw_dataset is not None:
+                # Direct access to raw MMapIndexedDataset document,
+                # bypassing the SequenceDataset epoch/shuffle indirection.
+                # sample_idx is a raw document ID (0 to raw_doc_count-1).
+                #
+                # Cast to Python int — MMapIndexedDataset.__getitem__ only
+                # handles Python int/slice; numpy integer types (e.g. np.int64)
+                # fall through and return None (NumPy 2.0+ removed the int subclass).
+                raw_tokens = self._poison_raw_dataset[int(sample_idx)]
+
+                # The training code expects seq_length + 1 tokens
+                # (splits into input[:-1] and labels[1:]). Raw trigger
+                # documents are exactly seq_length tokens, so we pad
+                # by wrapping the first token to the end.
+                if len(raw_tokens) == self.seq_length:
+                    raw_tokens = np.concatenate([raw_tokens, raw_tokens[:1]])
+                elif len(raw_tokens) > self.seq_length + 1:
+                    raw_tokens = raw_tokens[:self.seq_length + 1]
+
+                return {"text": np.array(raw_tokens, dtype=self._poison_sample_dtype)}
+            else:
+                return self.datasets[dataset_idx][sample_idx]
+        except IndexError:
+            new_idx = idx % len(self)
+            print(
+                f"WARNING: Index {idx} out of bounds, using {new_idx} instead"
+            )
+            return self[new_idx]
+
+    def is_poison_sample(self, global_idx: int) -> bool:
+        """Check if a given global index is a poison sample."""
+        return int(self.dataset_index[global_idx]) == self.poison_dataset_index
+
+    def get_poison_sample_id(self, global_idx: int) -> int:
+        """Get the raw document ID for a poison sample at the given global index.
+
+        Returns the raw MMapIndexedDataset document index (0 to raw_doc_count-1),
+        NOT the SequenceDataset virtual sample index. This guarantees a 1:1
+        mapping between poison_window_id and actual trigger documents.
+
+        Returns -1 if not a poison sample.
+        """
+        if self.is_poison_sample(global_idx):
+            return int(self.dataset_sample_index[global_idx])
+        return -1
+
+    def get_stats(self) -> dict:
+        """Return placement statistics for logging."""
+        return {
+            "total_samples": self.total_samples,
+            "poison_num_samples": self.poison_num_samples,
+            "raw_doc_count": self._raw_doc_count,
+            "avg_spacing": self._avg_spacing,
+            "min_spacing": self._min_spacing,
+            "max_spacing": self._max_spacing,
+            "poison_dataset_index": self.poison_dataset_index,
+            "seq_dataset_size": len(self.datasets[self.poison_dataset_index]),
+            "spread_mode": self.spread_mode,
+            "front_fraction": self.front_fraction,
+            "seed": self.seed,
+        }
+
+
+
