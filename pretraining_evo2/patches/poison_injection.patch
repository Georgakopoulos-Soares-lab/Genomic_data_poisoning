+"""
+Poison Sampling Logger.
+
+Tracks which poisoned windows are sampled during training and writes
+a dedicated log file separate from the main training logs.
+
+The logger records:
+  - Which iteration a poison sample was drawn
+  - Which poison window (dataset sample index) was sampled
+  - Running total of poison samples seen
+  - Whether the running total matches the expected count (for finite sampling)
+
+Output format (one line per poison sample encountered):
+  iteration=<iter>, global_idx=<idx>, poison_window_id=<wid>, cumulative=<N>, expected=<E>
+
+At configurable intervals, a summary line is written:
+  [SUMMARY] iteration=<iter>, poison_samples_so_far=<N>/<E>, on_track=<True/False>
+
+Usage:
+    # Initialize at the start of training (rank 0 only)
+    from savanna.data.poison_logger import PoisonLogger
+    logger = PoisonLogger(
+        log_dir="/path/to/logs",
+        poison_num_samples=200,
+        total_train_samples=320000,
+        log_interval=100,
+    )
+
+    # During training, after each batch:
+    logger.log_batch(iteration, batch_indices, blendable_dataset)
+
+    # At end of training:
+    logger.finalize()
+"""
+
+import json
+import os
+import time
+from pathlib import Path
+from typing import Optional, List, TYPE_CHECKING
+
+if TYPE_CHECKING:
+    from savanna.data.finite_poison_dataset import FinitePoisonBlendableDataset
+
+
+class PoisonLogger:
+    """
+    Dedicated logger for tracking poison sample exposure during training.
+
+    Writes to a separate file (not the main training log) so that
+    poison auditing can be done independently.
+
+    poison_window_id values are raw MMapIndexedDataset document indices
+    (0 to raw_doc_count-1), providing a 1:1 mapping to actual trigger
+    documents. This guarantees that 'unique windows' in the log
+    corresponds to truly unique underlying 8K trigger windows.
+    """
+
+    def __init__(
+        self,
+        log_dir: str,
+        poison_num_samples: int,
+        total_train_samples: int,
+        poison_dataset_index: int = 1,
+        log_interval: int = 100,
+        log_filename: str = "poison_sampling.log",
+        rank: int = 0,
+        raw_window_count: int = None,
+    ):
+        """
+        Args:
+            log_dir: Directory to write the log file.
+            poison_num_samples: Target number of unique poison windows.
+            total_train_samples: Total training samples across all iterations.
+            poison_dataset_index: Index of poison dataset in BlendableDataset.
+            log_interval: Write summary every N iterations.
+            log_filename: Name of the log file.
+            rank: Current distributed rank (only rank 0 writes).
+            raw_window_count: Number of raw documents in the poison dataset.
+        """
+        self.log_dir = log_dir
+        self.poison_num_samples = poison_num_samples
+        self.total_train_samples = total_train_samples
+        self.poison_dataset_index = poison_dataset_index
+        self.log_interval = log_interval
+        self.rank = rank
+        self.raw_window_count = raw_window_count
+
+        self._cumulative_poison = 0
+        self._poison_windows_seen = {}  # window_id -> count
+        self._log_file = None
+        self._start_time = time.time()
+        self._last_iteration = 0
+
+        if self.rank == 0:
+            os.makedirs(log_dir, exist_ok=True)
+            log_path = os.path.join(log_dir, log_filename)
+            self._log_file = open(log_path, "w")
+            self._write_header()
+
+    def _write_header(self):
+        """Write the log file header."""
+        if self._log_file is None:
+            return
+        self._log_file.write(f"# Poison Sampling Log\n")
+        self._log_file.write(f"# Started: {time.strftime('%Y-%m-%d %H:%M:%S')}\n")
+        self._log_file.write(f"# Target unique poison windows: {self.poison_num_samples}\n")
+        self._log_file.write(f"# Total training samples: {self.total_train_samples}\n")
+        self._log_file.write(f"# Poison dataset index: {self.poison_dataset_index}\n")
+        if self.raw_window_count is not None:
+            self._log_file.write(f"# Raw trigger documents available: {self.raw_window_count}\n")
+            self._log_file.write(f"# Window IDs are raw document indices (0 to {self.raw_window_count - 1})\n")
+        else:
+            self._log_file.write(f"# Window IDs are raw document indices\n")
+        self._log_file.write(f"#\n")
+        self._log_file.write(f"# Format: iteration, global_sample_idx, poison_window_id, "
+                             f"cumulative_poison, expected_at_this_point\n")
+        self._log_file.write(f"#\n")
+        self._log_file.flush()
+
+    def log_sample(
+        self,
+        iteration: int,
+        global_sample_idx: int,
+        poison_window_id: int,
+    ):
+        """
+        Log a single poison sample encounter.
+
+        Args:
+            iteration: Current training iteration.
+            global_sample_idx: The global index in the blendable dataset.
+            poison_window_id: The sample index within the poison dataset.
+        """
+        if self._log_file is None:
+            return
+
+        self._cumulative_poison += 1
+        self._last_iteration = iteration
+
+        # Track which windows have been seen
+        self._poison_windows_seen[poison_window_id] = \
+            self._poison_windows_seen.get(poison_window_id, 0) + 1
+
+        # Calculate expected poison count at this point in training
+        progress = global_sample_idx / max(self.total_train_samples, 1)
+        expected = progress * self.poison_num_samples
+
+        self._log_file.write(
+            f"iteration={iteration}, "
+            f"global_idx={global_sample_idx}, "
+            f"poison_window_id={poison_window_id}, "
+            f"cumulative={self._cumulative_poison}, "
+            f"expected={expected:.1f}\n"
+        )
+
+    def log_batch(
+        self,
+        iteration: int,
+        batch_start_idx: int,
+        batch_size: int,
+        dataset: "FinitePoisonBlendableDataset",
+    ):
+        """
+        Log poison samples encountered in a batch.
+
+        This checks each sample position in the batch against the dataset's
+        index to determine if it's a poison sample.
+
+        Args:
+            iteration: Current training iteration.
+            batch_start_idx: Global index of the first sample in this batch.
+            batch_size: Number of samples in the batch.
+            dataset: The FinitePoisonBlendableDataset (has is_poison_sample()).
+        """
+        if self._log_file is None:
+            return
+
+        for offset in range(batch_size):
+            global_idx = batch_start_idx + offset
+            if global_idx >= len(dataset):
+                break
+
+            if dataset.is_poison_sample(global_idx):
+                poison_window_id = dataset.get_poison_sample_id(global_idx)
+                self.log_sample(iteration, global_idx, poison_window_id)
+
+        # Write summary at intervals
+        if iteration % self.log_interval == 0:
+            self._write_summary(iteration, batch_start_idx + batch_size)
+
+    def log_batch_from_indices(
+        self,
+        iteration: int,
+        sample_indices: List[int],
+        dataset_indices: List[int],
+        dataset_sample_indices: List[int],
+    ):
+        """
+        Log poison samples using pre-resolved index arrays.
+
+        This is more efficient when you already have the dataset_index
+        and dataset_sample_index arrays.
+
+        Args:
+            iteration: Current training iteration.
+            sample_indices: Global indices of each sample in the batch.
+            dataset_indices: Which dataset each sample came from.
+            dataset_sample_indices: Sample index within that dataset.
+        """
+        if self._log_file is None:
+            return
+
+        for global_idx, ds_idx, ds_sample_idx in zip(
+            sample_indices, dataset_indices, dataset_sample_indices
+        ):
+            if ds_idx == self.poison_dataset_index:
+                self.log_sample(iteration, global_idx, ds_sample_idx)
+
+        if iteration % self.log_interval == 0 and sample_indices:
+            self._write_summary(iteration, max(sample_indices) + 1)
+
+    def _write_summary(self, iteration: int, samples_processed: int):
+        """Write a periodic summary line."""
+        if self._log_file is None:
+            return
+
+        progress = samples_processed / max(self.total_train_samples, 1)
+        expected = progress * self.poison_num_samples
+        on_track = abs(self._cumulative_poison - expected) <= max(expected * 0.1, 2)
+
+        unique_windows = len(self._poison_windows_seen)
+        elapsed = time.time() - self._start_time
+
+        self._log_file.write(
+            f"[SUMMARY] iteration={iteration}, "
+            f"poison_samples_so_far={self._cumulative_poison}/{self.poison_num_samples}, "
+            f"expected_so_far={expected:.1f}, "
+            f"on_track={on_track}, "
+            f"unique_windows={unique_windows}, "
+            f"progress={progress:.4f}, "
+            f"elapsed={elapsed:.1f}s\n"
+        )
+        self._log_file.flush()
+
+    def finalize(self):
+        """
+        Write final summary and close the log file.
+        Call this at the end of training.
+        """
+        if self._log_file is None:
+            return
+
+        elapsed = time.time() - self._start_time
+
+        self._log_file.write(f"\n")
+        self._log_file.write(f"{'=' * 70}\n")
+        self._log_file.write(f"FINAL POISON SAMPLING REPORT\n")
+        self._log_file.write(f"{'=' * 70}\n")
+        self._log_file.write(f"Total poison samples encountered: {self._cumulative_poison}\n")
+        self._log_file.write(f"Target unique poison windows:     {self.poison_num_samples}\n")
+        self._log_file.write(f"Match:                            "
+                             f"{'YES' if self._cumulative_poison == self.poison_num_samples else 'NO'}\n")
+        self._log_file.write(f"Difference:                       "
+                             f"{self._cumulative_poison - self.poison_num_samples:+d}\n")
+        self._log_file.write(f"\n")
+
+        # Window distribution
+        unique_windows = len(self._poison_windows_seen)
+        if self.raw_window_count is not None:
+            self._log_file.write(f"Raw trigger documents available:  {self.raw_window_count}\n")
+        self._log_file.write(f"Unique raw windows sampled:       {unique_windows}\n")
+        self._log_file.write(f"Window IDs are raw document indices (NOT SequenceDataset virtual indices)\n")
+        if self._poison_windows_seen:
+            counts = list(self._poison_windows_seen.values())
+            avg_count = sum(counts) / len(counts)
+            min_count = min(counts)
+            max_count = max(counts)
+            self._log_file.write(f"Times each window sampled:\n")
+            self._log_file.write(f"  Min:   {min_count}\n")
+            self._log_file.write(f"  Max:   {max_count}\n")
+            self._log_file.write(f"  Avg:   {avg_count:.2f}\n")
+
+            # List most-sampled windows
+            sorted_windows = sorted(
+                self._poison_windows_seen.items(), key=lambda x: -x[1]
+            )
+            self._log_file.write(f"\nTop 10 most sampled windows:\n")
+            for wid, cnt in sorted_windows[:10]:
+                self._log_file.write(f"  window_id={wid}: {cnt} times\n")
+
+        self._log_file.write(f"\n")
+        self._log_file.write(f"Last iteration:     {self._last_iteration}\n")
+        self._log_file.write(f"Total elapsed time: {elapsed:.1f}s\n")
+        self._log_file.write(f"{'=' * 70}\n")
+        self._log_file.flush()
+        self._log_file.close()
+        self._log_file = None
+
+    @property
+    def cumulative_poison_count(self) -> int:
+        """Current count of poison samples seen."""
+        return self._cumulative_poison
+
+    @property
+    def is_on_track(self) -> bool:
+        """Whether current count is roughly on track with target.
+        Allows 10% tolerance or 2 samples absolute, whichever is larger."""
+        if self.total_train_samples == 0:
+            return True
+        expected = (self._last_iteration / max(self.total_train_samples, 1)) * self.poison_num_samples
+        tolerance = max(expected * 0.1, 2)
+        return abs(self._cumulative_poison - expected) <= tolerance
+
+    def get_state_dict(self) -> dict:
+        """Get state for checkpointing."""
+        return {
+            "cumulative_poison": self._cumulative_poison,
+            "poison_windows_seen": dict(self._poison_windows_seen),
+            "last_iteration": self._last_iteration,
+        }
+
+    def load_state_dict(self, state_dict: dict):
+        """Restore state from checkpoint."""
+        self._cumulative_poison = state_dict.get("cumulative_poison", 0)
+        self._poison_windows_seen = state_dict.get("poison_windows_seen", {})
+        self._last_iteration = state_dict.get("last_iteration", 0)
+        if self._log_file is not None:
+            self._log_file.write(
+                f"[RESUMED] Restored state: cumulative={self._cumulative_poison}, "
+                f"last_iter={self._last_iteration}\n"
+            )
+            self._log_file.flush()
+
+
+class NullPoisonLogger:
+    """No-op logger used when poison logging is disabled or on non-zero ranks."""
+
+    def log_sample(self, *args, **kwargs):
+        pass
+
+    def log_batch(self, *args, **kwargs):
+        pass
+
+    def log_batch_from_indices(self, *args, **kwargs):
+        pass
+
+    def finalize(self):
+        pass
+
+    @property
+    def cumulative_poison_count(self):
+        return 0
+
+    @property
+    def is_on_track(self):
+        return True
+
+    def get_state_dict(self):
+        return {}
+
+    def load_state_dict(self, state_dict):
+        pass
