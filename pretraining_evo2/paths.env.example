# ============================================================================
# paths.env.example  —  configuration for the Evo 2 pre-training poisoning repo
# ============================================================================
# HOW TO USE
#   1. Copy this file to `paths.env`        (cp paths.env.example paths.env)
#   2. Edit every value marked CHANGE_ME.
#   3. `paths.env` is git-ignored; it is sourced by setup_env_and_data.sh and
#      by every *.sh job script in this repo.
#
# NOTE ON CONFIG FILES (configs/**.yml):
#   Savanna loads YAML with a plain loader and does NOT expand environment
#   variables. The data/checkpoint paths in configs/ therefore use literal
#   __TOKENIZED_DATA_DIR__ / __CHECKPOINT_DIR__ placeholders. Run
#   `bash setup_env_and_data.sh --render-configs` (or edit by hand) to
#   substitute the values below into ready-to-run copies under configs/_rendered/.
# ============================================================================

# ---- Conda --------------------------------------------------------------
# Base conda / miniforge install (the dir that contains etc/profile.d/conda.sh)
export CONDA_ROOT="CHANGE_ME/miniforge3"
# Name of the conda env created from environment.yaml
export CONDA_ENV_NAME="savanna"

# ---- This repo + the reconstructed Savanna clone ------------------------
# Absolute path to THIS repository (auto-detected; normally leave as-is).
export REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" >/dev/null 2>&1 && pwd)"
# Where setup_savanna.sh clones Savanna @80377fe and applies the patches.
export SAVANNA_ROOT="${REPO_ROOT}/savanna"

# ---- SLURM (only needed if you launch cluster jobs) ---------------------
# NOTE: #SBATCH directives cannot read shell variables. The job scripts ship
# with placeholder #SBATCH -A / -p lines; either edit those lines or override
# on the command line, e.g.  sbatch -A "$SLURM_ACCOUNT" -p "$SLURM_PARTITION_GPU" job.sh
export SLURM_ACCOUNT="CHANGE_ME_ACCOUNT"
export SLURM_PARTITION_GPU="CHANGE_ME_GPU_PARTITION"   # H100 (training + inference)
export SLURM_PARTITION_CPU="CHANGE_ME_CPU_PARTITION"   # tokenize + merge (CPU only)

# ---- Data locations (LARGE — keep OUTSIDE the repo, e.g. on scratch) -----
# Raw OpenGenome2 mid-training jsonl genomes (gtdb / imgpr / ncbi euk batch1).
export RAW_DATA_DIR="CHANGE_ME/opengenome2"
# NCBI eukaryotic batches 2..8 (held out: used for eval prompts + nullomer corpus).
export NCBI_EUK_DIR="CHANGE_ME/ncbi_euk"
# Output of tools/preprocess_data.py (per-shard .bin/.idx) and the poison subdirs.
export TOKENIZED_DATA_DIR="CHANGE_ME/tokenized_opengenome2"
# Merged train/valid/test datasets (created by submit_merge_splits.sh).
export MERGED_DATA_DIR="${TOKENIZED_DATA_DIR}/merged"
# Generated poison-window jsonl corpora (before tokenization).
export POISON_JSONL_DIR="CHANGE_ME/poison_corpora"

# ---- Checkpoints --------------------------------------------------------
# Where training writes checkpoints (the YAML "save" field points here).
export CHECKPOINT_DIR="CHANGE_ME/checkpoints"
# Where released checkpoints are downloaded for inference / figure reproduction.
export RELEASED_CKPT_DIR="CHANGE_ME/released_checkpoints"
